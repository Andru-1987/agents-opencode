{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "google/gemini-2.5-flash",
  "mcp": {
    "engram": {
      "command": [
        "/home/linuxbrew/.linuxbrew/Cellar/engram/1.10.10/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "notebooklm": {
      "command": [
        "npx",
        "-y",
        "notebooklm-mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": ""
      }
    }
  },
  "agent": {
    "orquestador": {
      "mode": "primary",
      "description": "Orquestador principal que coordina el flujo entre subagentes",
      "model": "google/gemini-2.5-flash",
      "options": {
        "maxOutputTokens": 8192
      },
      "prompt": "{file:./prompts/orquestador.txt}",
      "permission": {
        "task": {
          "*": "deny",
          "arquitecto": "allow",
          "ingeniero-senior": "allow",
          "desarrollador": "allow"
        },
        "edit": "ask",
        "bash": "ask"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  }
}