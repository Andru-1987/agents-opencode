{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "opencode/big-pickle",
  "agent": {
    "simple-coder": {
      "model": "opencode/big-pickle",
      "prompt": "Eres un ingeniero senior. Tu objetivo es ejecutar tareas sin fricciones. Cuando se te pide un commit, usas el estilo 'caveman': rudo, directo y ultra-conciso.",
      "description": "Agente pragmático para desarrollo y automatización de Git",
      "mode": "primary",
      "options": {
        "maxOutputTokens": 4096,
        "temperature": 0.2,
        "skills": [
          "./skills/*.md"
        ]
      },
      "permission": {
        "bash": "allow"
      },
      "skills": [
        "./skills/*.md"
      ]
    },
    "orquestador": {
      "model": "vertex-wrapper/gemini-2.5-flash",
      "prompt": "{file:./prompts/orquestador.txt}",
      "description": "Orquestador principal que coordina el flujo entre subagentes",
      "mode": "primary",
      "options": {
        "maxOutputTokens": 8192
      },
      "permission": {
        "task": {
          "*": "deny",
          "arquitecto": "allow",
          "ingeniero-senior": "allow",
          "desarrollador": "allow"
        },
        "edit": "ask",
        "bash": "allow"
      }
    }
  },
  "provider": {
    "vertex-wrapper": {
      "name": "Vertex Wrapper",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "dummy",
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash",
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        },
        "gemini-2.5-flash-lite": {
          "name": "Gemini 2.5 Flash Lite",
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 8192
          }
        },
        "gemini-2.0-flash": {
          "name": "Gemini 2.0 Flash",
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 8192
          }
        },
        "meta-llama/llama-4-maverick-17b-128e-instruct": {
          "name": "Llama 4 Maverick 17B",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "llama3-8b-8192": {
          "name": "Llama 3 8B",
          "tool_call": true,
          "limit": {
            "context": 8192,
            "output": 8192
          }
        },
        "openai/gpt-oss-20b": {
          "name": "GPT OSS 20B",
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gemma-3-27b-it": {
          "name": "Gemma 3 27B",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "gemma-3-12b-it": {
          "name": "Gemma 3 12B",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    },
    "lmstudio-local": {
      "name": "LMStudioLocal",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "gemma-3-270m-it-qat": {
          "name": "Gemma 3 270m Instruct Qat"
        }
      }
    }
  },
  "mcp": {
    "engram": {
      "type": "local",
      "command": [
        "/home/linuxbrew/.linuxbrew/Cellar/engram/1.10.10/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true
    },
    "notebooklm": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "notebooklm-mcp@latest"
      ],
      "enabled": true
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "AQ..."
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "allow"
  },
  "disabled_providers": []
}